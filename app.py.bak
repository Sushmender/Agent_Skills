      <span style="color:{n_col}; font-weight:600;">{n_lbl}</span>
    </div>
    """, unsafe_allow_html=True)

    st.divider()
    st.markdown("### 🤖 Active Subagents")
    for icon, name, role in [
        ("🌐", "docs_researcher", "Official Documentation"),
        ("💻", "repo_analyzer",   "GitHub Repositories"),
