load_dotenv()

class UnderscoreMcpToolset(McpToolset):
    async def get_tools(self, readonly_context=None):
        tools = await super().get_tools(readonly_context)
        for t in tools:
            if "-" in t.name:
                t.name = t.name.replace("-", "_")
        return tools


